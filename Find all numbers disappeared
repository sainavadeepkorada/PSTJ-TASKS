import java.util.*;

class Solution {
    public List<Integer> findDisappearedNumbers(int[] nums) {
        List<Integer> result = new ArrayList<>();
        
        // Step 1: Iterate through the array and mark visited indices
        for (int i = 0; i < nums.length; i++) {
            // Get the value as an index (use Math.abs because it might already be negative)
            int index = Math.abs(nums[i]) - 1;
            
            // Mark the value at that index as negative to signify "seen"
            if (nums[index] > 0) {
                nums[index] = -nums[index];
            }
        }
        
        // Step 2: Iterate again; any index that is still positive was never visited
        for (int i = 0; i < nums.length; i++) {
            if (nums[i] > 0) {
                result.add(i + 1);
            }
        }
        
        return result;
    }
}
