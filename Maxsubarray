class Result {

    /*
     * Complete the 'maxSubarray' function below.
     *
     * The function is expected to return an INTEGER_ARRAY.
     * The function accepts INTEGER_ARRAY arr as parameter.
     */

public static List<Integer> maxSubarray(List<Integer> arr) {
        // Kadane's Algorithm for Maximum Subarray
        int maxSoFar = arr.get(0);
        int currentMax = arr.get(0);
        
        // Logic for Maximum Subsequence
        int maxSubsequence = arr.get(0);
        
        for (int i = 1; i < arr.size(); i++) {
            int num = arr.get(i);
            
            // Subarray logic: start fresh or continue?
            currentMax = Math.max(num, currentMax + num);
            maxSoFar = Math.max(maxSoFar, currentMax);
            
            // Subsequence logic:
            // 1. If we find a positive number, add it to the sum (if sum was positive)
            // 2. If maxSubsequence is negative, replace it with a larger number
            // 3. If num is positive and maxSubsequence was negative, take num
            if (num > 0) {
                if (maxSubsequence > 0) {
                    maxSubsequence += num;
                } else {
                    maxSubsequence = num;
                }
            } else {
                // If both are negative, keep the one closer to zero
                if (maxSubsequence < 0) {
                    maxSubsequence = Math.max(maxSubsequence, num);
                }
            }
        }
        
        return Arrays.asList(maxSoFar, maxSubsequence);
    }

}

public class Solution {
    public static void main(String[] args) throws IOException {
        BufferedReader bufferedReader = new BufferedReader(new InputStreamReader(System.in));
        BufferedWriter bufferedWriter = new BufferedWriter(new FileWriter(System.getenv("OUTPUT_PATH")));

        int t = Integer.parseInt(bufferedReader.readLine().trim());

        for (int tItr = 0; tItr < t; tItr++) {
            int n = Integer.parseInt(bufferedReader.readLine().trim());

            String[] arrTemp = bufferedReader.readLine().replaceAll("\\s+$", "").split(" ");

            List<Integer> arr = new ArrayList<>();

            for (int i = 0; i < n; i++) {
                int arrItem = Integer.parseInt(arrTemp[i]);
                arr.add(arrItem);
            }

            List<Integer> result = Result.maxSubarray(arr);

            for (int i = 0; i < result.size(); i++) {
                bufferedWriter.write(String.valueOf(result.get(i)));

                if (i != result.size() - 1) {
                    bufferedWriter.write(" ");
                }
            }

            bufferedWriter.newLine();
        }

        bufferedReader.close();
        bufferedWriter.close();
    }
}
