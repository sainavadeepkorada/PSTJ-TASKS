import java.util.Comparator;

class Checker implements Comparator<Player> {

    @Override
    public int compare(Player a, Player b) {
        if (b.score != a.score) {
            return b.score - a.score; // descending score
        }
        return a.name.compareTo(b.name); // ascending name
    }
}

