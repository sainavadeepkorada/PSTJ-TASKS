class Result {

    /*
     * Complete the 'matrixRotation' function below.
     *
     * The function accepts following parameters:
     *  1. 2D_INTEGER_ARRAY matrix
     *  2. INTEGER r
     */
public static void matrixRotation(List<List<Integer>> matrix, int r) {
        int m = matrix.size();
        int n = matrix.get(0).size();
        int numLayers = Math.min(m, n) / 2;

        // Create a 2D array for easier index access than List<List<Integer>>
        int[][] res = new int[m][n];
        for (int i = 0; i < m; i++) {
            for (int j = 0; j < n; j++) {
                res[i][j] = matrix.get(i).get(j);
            }
        }

        for (int layer = 0; layer < numLayers; layer++) {
            List<Integer> ring = new ArrayList<>();
            
            // 1. Extract Layer (Anti-clockwise order)
            // Top row
            for (int j = layer; j < n - 1 - layer; j++) ring.add(res[layer][j]);
            // Right column
            for (int i = layer; i < m - 1 - layer; i++) ring.add(res[i][n - 1 - layer]);
            // Bottom row
            for (int j = n - 1 - layer; j > layer; j--) ring.add(res[m - 1 - layer][j]);
            // Left column
            for (int i = m - 1 - layer; i > layer; i--) ring.add(res[i][layer]);

            // 2. Calculate effective rotation
            int rotation = r % ring.size();
            
            // 3. Re-insert rotated values
            int ringIndex = rotation; // Start from the 'rotation' offset
            
            // Re-map Top row
            for (int j = layer; j < n - 1 - layer; j++) {
                res[layer][j] = ring.get(ringIndex % ring.size());
                ringIndex++;
            }
            // Re-map Right column
            for (int i = layer; i < m - 1 - layer; i++) {
                res[i][n - 1 - layer] = ring.get(ringIndex % ring.size());
                ringIndex++;
            }
            // Re-map Bottom row
            for (int j = n - 1 - layer; j > layer; j--) {
                res[m - 1 - layer][j] = ring.get(ringIndex % ring.size());
                ringIndex++;
            }
            // Re-map Left column
            for (int i = m - 1 - layer; i > layer; i--) {
                res[i][layer] = ring.get(ringIndex % ring.size());
                ringIndex++;
            }
        }

        // Print the final matrix
        StringBuilder sb = new StringBuilder();
        for (int i = 0; i < m; i++) {
            for (int j = 0; j < n; j++) {
                sb.append(res[i][j]).append(" ");
            }
            sb.append("\n");
        }
        System.out.print(sb.toString());
    }
}

public class Solution {
    public static void main(String[] args) throws IOException {
        BufferedReader bufferedReader = new BufferedReader(new InputStreamReader(System.in));

        String[] firstMultipleInput = bufferedReader.readLine().replaceAll("\\s+$", "").split(" ");

        int m = Integer.parseInt(firstMultipleInput[0]);

        int n = Integer.parseInt(firstMultipleInput[1]);

        int r = Integer.parseInt(firstMultipleInput[2]);

        List<List<Integer>> matrix = new ArrayList<>();

        for (int i = 0; i < m; i++) {
            String[] matrixRowTempItems = bufferedReader.readLine().replaceAll("\\s+$", "").split(" ");

            List<Integer> matrixRowItems = new ArrayList<>();

            for (int j = 0; j < n; j++) {
                int matrixItem = Integer.parseInt(matrixRowTempItems[j]);
                matrixRowItems.add(matrixItem);
            }

            matrix.add(matrixRowItems);
        }

        Result.matrixRotation(matrix, r);

        bufferedReader.close();
    }
}
