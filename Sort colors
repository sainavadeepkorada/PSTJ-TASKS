class Solution {
    public void sortColors(int[] nums) {
        int low = 0;
        int mid = 0;
        int high = nums.length - 1;

        while (mid <= high) {
            if (nums[mid] == 0) {
                // If we find a 0, swap it with the 'low' pointer
                swap(nums, low, mid);
                low++;
                mid++;
            } else if (nums[mid] == 1) {
                // If we find a 1, it's already in the "middle" zone, just move on
                mid++;
            } else { // nums[mid] == 2
                // If we find a 2, swap it with the 'high' pointer
                swap(nums, mid, high);
                // Crucial: Don't increment mid here because the swapped 
                // value from 'high' needs to be inspected.
                high--;
            }
        }
    }

    private void swap(int[] nums, int i, int j) {
        int temp = nums[i];
        nums[i] = nums[j];
        nums[j] = temp;
    }
}
