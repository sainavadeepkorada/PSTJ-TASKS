List<Integer> roundedGrades = new ArrayList<>();

    for (int grade : grades) {
        // Condition 1: If grade is less than 38, no rounding occurs
        if (grade < 38) {
            roundedGrades.add(grade);
        } else {
            int nextMultipleOfFive = grade;
            // Find the next multiple of 5
            // If it's already a multiple of 5, the remainder is 0
            int remainder = grade % 5;
            
            if (remainder >= 3) {
                // If remainder is 3, next multiple is grade + 2
                // If remainder is 4, next multiple is grade + 1
                nextMultipleOfFive = grade + (5 - remainder);
            }

            // If the difference was less than 3, nextMultipleOfFive will be higher
            // Otherwise, it stays the same as 'grade'
            roundedGrades.add(nextMultipleOfFive);
        }
    }
    return roundedGrades;
}
