class Solution {
    public List<String> stringMatching(String[] words) {
        List<String> result = new ArrayList<>();
        
        for (int i = 0; i < words.length; i++) {
            for (int j = 0; j < words.length; j++) {
                // We don't compare a word to itself
                // and we check if the current word is a substring of words[j]
                if (i != j && words[j].contains(words[i])) {
                    result.add(words[i]);
                    // Break once a match is found to avoid duplicate entries
                    break;
                }
            }
        }
        
        return result;
    }
}
